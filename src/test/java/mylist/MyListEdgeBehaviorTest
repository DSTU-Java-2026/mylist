package mylist;

import org.junit.jupiter.api.Test;

import static org.junit.jupiter.api.Assertions.*;

public class MyListEdgeBehaviorTest {

    @Test
    void addAtBounds() {
        MyList list = new MyList();

        list.add(0, 10);
        assertEquals(10, list.get(0));

        list.add(1, 20);
        assertEquals(20, list.get(1));

        list.add(0, 5);
        assertEquals(5, list.get(0));
    }

    @Test
    void removeLastElementViaRemove() {
        MyList list = new MyList();
        list.add(1);
        list.add(2);

        list.remove(1);

        assertEquals(1, list.size());
        assertEquals(1, list.get(0));
    }

    @Test
    void shiftAfterRemove() {
        MyList list = new MyList(new int[]{1, 2, 3, 4});

        list.remove(1);

        assertArrayEquals(new int[]{1, 3, 4}, list.toArray());
    }

    @Test
    void multipleInsertionsInMiddle() {
        MyList list = new MyList();

        for (int i = 0; i < 10; i++) {
            list.add(i);
        }

        list.add(5, 100);
        list.add(5, 200);

        assertEquals(200, list.get(5));
        assertEquals(100, list.get(6));
    }

    @Test
    void toArrayReturnsCopy() {
        MyList list = new MyList(new int[]{1, 2, 3});

        int[] arr = list.toArray();
        arr[0] = 999;

        assertEquals(1, list.get(0));
    }

    @Test
    void equalsAfterMutations() {
        MyList a = new MyList(new int[]{1, 2, 3});
        MyList b = new MyList(new int[]{1, 2, 3});

        a.remove(1);
        a.add(1, 2);

        assertEquals(a, b);
    }
}